{
  "name": "ai-driven-test",
  "version": "2.0.0",
  "private": true,
  "description": "AI-driven development template with backend and frontend",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "judge:backend": "cd backend && npm run judge",
    "judge:frontend": "cd frontend && npm run judge",
    "judge:all": "npm run judge:backend && npm run judge:frontend",
    "judge": "npm run judge:all",
    "install:all": "cd backend && npm install && cd ../frontend && npm install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ai-driven-test.git"
  },
  "keywords": [
    "ai-driven-development",
    "claude-code",
    "template",
    "fullstack",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
